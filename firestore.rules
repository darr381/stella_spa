rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Strict rules for the custom login flow
    match /users/{userId} {
      // Allow fetching a specific user document if the ID (phone number) is known
      allow get: if true;
      // Completely block listing/downloading the database
      allow list: if false;
      
      // Allow creating a new user ONLY if:
      // 1. They are providing exactly name, phone, and createdAt
      // 2. The phone number strictly matches 8 digits starting with 8 or 9
      // 3. The name is a non-empty string
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'createdAt'])
                    && request.resource.data.keys().hasOnly(['name', 'phone', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.phone is string
                    && request.resource.data.phone.matches('^[89][0-9]{7}$');
      
      // Prevent any tampering, modifying, or deleting of existing users
      allow update, delete: if false;
    }

    // Employee Profiles
    match /employees/{employeeId} {
      allow get, list, create, update: if true;
      allow delete: if false;
    }

    // Bookings (Subcollection)
    match /therapists/{therapistId}/bookings/{bookingId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    
    // Allow collection group query across all bookings
    match /{path=**}/bookings/{bookingId} {
      allow read: if true;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}